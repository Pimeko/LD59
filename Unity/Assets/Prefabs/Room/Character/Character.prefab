  - {fileID: 21300000, guid: 2cca38f3fe07a9a40af0b4a2c605f747, type: 3}
  bubbleGO: {fileID: 1845199247700024863}
  bubbleText: {fileID: 1711944410394892531}
  textsNoise:
  - What's that weird noise?
  - It's a bit noisy
  textsFast:
  - It's way too fast!!!
  - It should be slower ...
  textsSlow:
  - So slow... I'm falling asleep
  - Mmh It should be faster
  textsVolume:
  - I can't hear anything
  - It should be louder...
  textsWin:
  - Now we're talking!
  - Hell yeah
  - Woohooooo
  - That's what I call music!
  textsFail:
  - That's it I'm leaving.
  - This Jukebox is too broken.
  durationBubble: 5
